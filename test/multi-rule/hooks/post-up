#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$(dirname "$SCRIPT_DIR")"
TOOLS_DIR="$(cd "$CONFIG_DIR/../../tools" && pwd)"

# Wait for cloud-init to finish
migrant.sh ssh -- 'sudo cloud-init status --wait'

# Detect default router for the lan-ip check
router=$(ip route | awk '/default/{print $3; exit}')

# Copy netcheck.py into the workspace so the VM can reach it
cp "$TOOLS_DIR/netcheck.py" "$CONFIG_DIR/workspace/netcheck.py"

# Run the check from inside the VM with both flags
migrant.sh ssh -- "uv run ~/workspace/netcheck.py --no-interactive --host-port tcp/9999 --lan-ip $router"

# Clean up
rm -f "$CONFIG_DIR/workspace/netcheck.py"
