#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$(dirname "$SCRIPT_DIR")"
TOOLS_DIR="$(cd "$CONFIG_DIR/../../tools" && pwd)"

# Wait for cloud-init to finish
migrant.sh ssh -- 'sudo cloud-init status --wait'

# Copy netcheck.py into the workspace so the VM can reach it
cp "$TOOLS_DIR/netcheck.py" "$CONFIG_DIR/workspace/netcheck.py"

# Run the check from inside the VM (no --host-port, no --lan-ip — just verify basics)
migrant.sh ssh -- 'uv run ~/workspace/netcheck.py --no-interactive'

# Clean up
rm -f "$CONFIG_DIR/workspace/netcheck.py"

# Manual check: confirm the VM can reach the gateway on port 53 (dnsmasq)
# With isolation disabled this TCP connection must succeed
migrant.sh ssh -- 'python3 -c "import socket; s=socket.socket(); s.settimeout(3); s.connect((\"192.168.200.1\", 53)); print(\"connected\")"'
echo "no-isolation: gateway TCP connection succeeded as expected"
