#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$(dirname "$SCRIPT_DIR")"
TOOLS_DIR="$(cd "$CONFIG_DIR/../../tools" && pwd)"

# Wait for cloud-init to finish
migrant.sh ssh -- 'sudo cloud-init status --wait'

# Copy netcheck.py into the workspace so the VM can reach it
cp "$TOOLS_DIR/netcheck.py" "$CONFIG_DIR/workspace/netcheck.py"

# Run netcheck in isolation-only mode (no --host-port, no --lan-ip)
migrant.sh ssh -- 'uv run ~/workspace/netcheck.py --no-interactive'

# Clean up
rm -f "$CONFIG_DIR/workspace/netcheck.py"

# Additional manual check: verify the VM cannot reach the gateway on port 80.
# In pure isolation mode this connection MUST fail — a successful connect
# would mean isolation is broken.
if migrant.sh ssh -- 'python3 -c "import socket; s=socket.socket(); s.settimeout(3); s.connect((\"192.168.200.1\", 80))"' 2>/dev/null; then
  echo "FAIL: VM was able to connect to gateway 192.168.200.1:80 — isolation is broken" >&2
  exit 1
fi

echo "PASS: gateway connection correctly refused (isolation working)"
