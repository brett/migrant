#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$(dirname "$SCRIPT_DIR")"
TOOLS_DIR="$(cd "$CONFIG_DIR/../../tools" && pwd)"

# Wait for cloud-init to finish
migrant.sh ssh -- 'sudo cloud-init status --wait'

# Detect the default router
router=$(ip route | awk '/default/{print $3; exit}')

# Copy netcheck into the shared workspace
cp "$TOOLS_DIR/netcheck.py" "$CONFIG_DIR/workspace/netcheck.py"

# Run the LAN host connectivity check
migrant.sh ssh -- "uv run ~/workspace/netcheck.py --no-interactive --lan-ip $router"

# Clean up
rm -f "$CONFIG_DIR/workspace/netcheck.py"
